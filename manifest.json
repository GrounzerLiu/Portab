{
  "manifest_version": 3,
  "name": "Portab",
  "default_locale": "zh_CN",
  "version": "1.0.0",
  "description": "__MSG_extDescription__",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "permissions": [
    "history",
    "storage",
    "favicon"
  ],
  "host_permissions": [
    "https://www.bing.com/*",
    "https://cn.bing.com/*",
    "https://api.bing.com/*",
    "https://www.google.com/*",
    "https://suggestqueries.google.com/*",
    "https://suggestion.baidu.com/*",
    "https://duckduckgo.com/*",
    "https://icons.duckduckgo.com/*",
    "https://picsum.photos/*",
    "https://fastly.picsum.photos/*",
    "https://api.paugram.com/*",
    "https://api.nasa.gov/*",
    "https://apod.nasa.gov/*",
    "https://api.faviconkit.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Portab"
  }
}
